<Window x:Class="TK_Abazov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geometry Calculator" Height="500" Width="450"
        Background="#F5F6F7" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DADCE0"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Style.Resources>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Расчет площади" FontSize="24" FontWeight="Bold" Foreground="#202124" Margin="0,0,0,20"/>

            <TextBlock Text="Выберите фигуру:" FontSize="14" Foreground="#5F6368" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <RadioButton Name="RbRectangle" Content="Прямоугольник" Margin="0,0,15,0" Checked="RadioButton_Checked" IsChecked="True"/>
                <RadioButton Name="RbCircle" Content="Круг" Margin="0,0,15,0" Checked="RadioButton_Checked"/>
                <RadioButton Name="RbTriangle" Content="Треугольник" Checked="RadioButton_Checked"/>
            </StackPanel>

            <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E8EAED" BorderThickness="1">
                <StackPanel>
                    <Label x:Name="Lbl1" Content="Сторона A" FontWeight="Medium"/>
                    <TextBox x:Name="Txt1"/>

                    <Label x:Name="Lbl2" Content="Сторона B" FontWeight="Medium"/>
                    <TextBox x:Name="Txt2"/>

                    <Label x:Name="Lbl3" Content="Сторона C" FontWeight="Medium" Visibility="Collapsed"/>
                    <TextBox x:Name="Txt3" Visibility="Collapsed"/>
                    
                    <Button Content="Рассчитать площадь" Style="{StaticResource PrimaryButton}" Click="BtnCalculate_Click" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Margin="0,20,0,0" Background="#E8F0FE" CornerRadius="8" Padding="15">
                <TextBlock x:Name="TxtResult" Text="Результат: -" FontSize="18" FontWeight="Bold" Foreground="#1967D2" HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
