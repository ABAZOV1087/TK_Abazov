<Window x:Class="TK_Abazov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вариант 14 - Площади фигур" Height="400" Width="500">
    <Grid Margin="20">
        <StackPanel>
            <GroupBox Header="Вид фигуры" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Name="RbRectangle" Content="прямоугольник" Margin="5" Checked="RadioButton_Checked"/>
                    <RadioButton Name="RbCircle" Content="круг" Margin="5" Checked="RadioButton_Checked"/>
                    <RadioButton Name="RbTriangle" Content="треугольник" Margin="5" Checked="RadioButton_Checked"/>
                </StackPanel>
            </GroupBox>

            <Label x:Name="Lbl1" Content="1-я сторона:" Visibility="Collapsed"/>
            <TextBox x:Name="Txt1" Visibility="Collapsed" Margin="0,0,0,5"/>

            <Label x:Name="Lbl2" Content="2-я сторона:" Visibility="Collapsed"/>
            <TextBox x:Name="Txt2" Visibility="Collapsed" Margin="0,0,0,5"/>

            <Label x:Name="Lbl3" Content="3-я сторона:" Visibility="Collapsed"/>
            <TextBox x:Name="Txt3" Visibility="Collapsed" Margin="0,0,0,10"/>

            <Button Content="Вычислить" Click="BtnCalculate_Click" Width="100" HorizontalAlignment="Left"/>

            <TextBlock x:Name="TxtResult" FontSize="16" FontWeight="Bold" Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</Window>
